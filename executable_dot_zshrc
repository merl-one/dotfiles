# --- zsh: Minimal, portable configuration ---
# Using defaults for maximum compatibility

# Basic initialization
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_REDUCE_BLANKS

# Standard completion (zsh built-in)
autoload -Uz compinit && compinit
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# Kubectl completion
if command -v kubectl &>/dev/null; then
  source <(kubectl completion zsh)
  compdef __start_kubectl k
fi

# git completion (built-in to zsh)
autoload -Uz bashcompinit && bashcompinit
complete -o default -o nospace -F __git_wrap__git_main git

# Add local bin to PATH
export PATH="$HOME/.local/bin:$PATH"

# Standard shell settings
set -o vi                          # Vi-like editing (ESC for normal mode)
export EDITOR=vi                   # Default editor
export PAGER=less                  # Default pager

# Initialize starship prompt
eval "$(starship init zsh)"

# Set home directory for WSL2 (before aliases)
export HOME="/mnt/c/Users/jason/Documents"

# Aliases - eza with icons, lazygit, and common shortcuts
alias ls='eza -la --icons'
alias la='eza -la --icons'
alias ll='eza -l --icons'
alias l='eza --icons'
alias lg='lazygit'
alias k='kubectl'
alias v='nvim'
alias grep='grep --color=auto'
alias diff='diff --color=auto'
alias gs='git status'
alias gp='git pull'
alias gm='git commit -m'

# Start in home directory
cd "$HOME" 2>/dev/null
